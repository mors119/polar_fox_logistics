{
  "name": "polar_fox",
  "version": "1.0.0",
  "private": true,
  "description": "Google apps script automation project",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "npm run clean && node esbuild.config.js",
    "deploy:local": "npm run build && clasp push",
    "pull": "clasp pull",
    "push": "npm run build && clasp push",
    "clasp:config": "node scripts/write-clasp-config.mjs"
  },
  "keywords": [
    "google-apps-script",
    "typescript",
    "clasp",
    "esbuild",
    "github-actions",
    "template"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.98",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.6",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
